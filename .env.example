# ── Supabase (SAME project as the live practice planner) ──────────────
# Public — safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. Bypasses RLS for usage metering
# and reading the subscriptions table.
SUPABASE_SERVICE_ROLE_KEY=

# Shared auth cookie domain so login carries across the platform + this
# subdomain. In production set to: .aicoachingsolutions.net
# Leave blank for local dev.
NEXT_PUBLIC_COOKIE_DOMAIN=

# ── Email (SMTP — your domain mailbox, e.g. SiteGround) ───────────────
# Free breakdowns are emailed (lead capture). Use the mailbox you created on
# the domain. Find these under SiteGround → Email → Accounts → Mail config.
SMTP_HOST=          # e.g. mail.aicoachingsolutions.net (or the SiteGround server)
SMTP_PORT=465       # 465 (SSL) or 587 (STARTTLS)
SMTP_USER=          # full address, e.g. noreply@aicoachingsolutions.net
SMTP_PASS=          # that mailbox's password
# From address — usually must equal SMTP_USER for shared hosting.
EMAIL_FROM=Coach Vach <noreply@aicoachingsolutions.net>

# ── OpenAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Defaults to gpt-5.4-mini (precision matters — this is the credibility funnel).
# Use the exact model id from your OpenAI dashboard if this alias isn't accepted
# (the old repo used gpt-5.4-mini-2026-03-17).
OPENAI_MODEL=gpt-5.4-mini
# Vision model for video/photo frame analysis (must support images). Default gpt-4o.
OPENAI_VISION_MODEL=gpt-4o

# ── Stripe (same account as Break90) ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs — defaults are baked into the code; only set these to override.
STRIPE_PRICE_SWING_PACK=price_1TlKzZIGI93DDKQOF5o1tlZN
STRIPE_PRICE_PRO_MONTH=price_1TLOLeIGI93DDKQOwbikz6tt
STRIPE_PRICE_PRO_YEAR=price_1TLOM2IGI93DDKQOhXwuxtV8
